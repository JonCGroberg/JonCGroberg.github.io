---
---

<header class="sticky z-50 w-full pointer-events-none" id="site-header">
	<div class="max-w-[480px] mx-auto px-4 pt-2 pb-1 relative">

		<!-- Full pill nav (visible at top) -->
		<nav id="nav-full" class="glass-nav nav-full flex items-center justify-between px-4 h-11 pointer-events-auto">
			<!-- Left: nav links -->
			<div class="flex items-center gap-0.5">
				<a
					href="/"
					class="px-3 py-1.5 rounded-xl text-sm font-semibold transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee]"
				>About</a>
				<a
					href="/resume.pdf"
					target="_blank"
					rel="noopener"
					class="px-3 py-1.5 rounded-xl text-sm font-semibold transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee] flex items-center gap-1"
				>
					Resume
					<svg class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
			</div>

			<!-- Right: icons -->
			<div class="flex items-center gap-1">
				<a
					href="https://github.com/joncgroberg"
					target="_blank"
					rel="noopener"
					aria-label="GitHub"
					class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee]"
				>
					<svg viewBox="0 0 16 16" class="w-4 h-4" fill="currentColor" aria-hidden="true">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
					</svg>
				</a>
				<a
					href="https://www.linkedin.com/in/jonathan-groberg/"
					target="_blank"
					rel="noopener"
					aria-label="LinkedIn"
					class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-blue-600 dark:text-sky-400"
				>
					<svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
					</svg>
				</a>
				<button
					type="button"
					data-theme-toggle
					aria-label="Toggle dark mode"
					class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee]"
				>
					<svg class="w-4 h-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="4"></circle>
						<path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.93-7.07-1.41 1.41M6.34 17.66l-1.41 1.41"></path>
					</svg>
					<svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
					</svg>
				</button>
			</div>
		</nav>

		<!-- Split nav (visible on scroll down) -->
		<div id="nav-split" class="nav-split absolute inset-x-4 top-0 flex justify-between items-start">

			<!-- Left: hamburger menu -->
			<button
				id="nav-menu-btn"
				type="button"
				aria-label="Menu"
				class="glass-nav w-10 h-10 flex items-center justify-center pointer-events-auto text-[#18181c] dark:text-[#e4e4ee]"
			>
				<svg id="menu-icon-open" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
					<line x1="4" y1="6" x2="20" y2="6"></line>
					<line x1="4" y1="12" x2="20" y2="12"></line>
					<line x1="4" y1="18" x2="20" y2="18"></line>
				</svg>
				<svg id="menu-icon-close" class="w-[18px] h-[18px] hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>

			<!-- Right: GitHub + LinkedIn stacked -->
			<div class="glass-nav flex flex-col p-1 gap-0.5 pointer-events-auto">
				<a
					href="https://github.com/joncgroberg"
					target="_blank"
					rel="noopener"
					aria-label="GitHub"
					class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee]"
				>
					<svg viewBox="0 0 16 16" class="w-4 h-4" fill="currentColor" aria-hidden="true">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
					</svg>
				</a>
				<a
					href="https://www.linkedin.com/in/jonathan-groberg/"
					target="_blank"
					rel="noopener"
					aria-label="LinkedIn"
					class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-blue-600 dark:text-sky-400"
				>
					<svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
						<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
					</svg>
				</a>
			</div>
		</div>

	</div>

	<!-- Menu dropdown (shown when hamburger is clicked) -->
	<div id="nav-menu-dropdown" class="nav-menu-dropdown max-w-[480px] mx-auto px-4 pointer-events-none">
		<div class="glass-nav nav-menu-panel" style="border-radius: 16px;">
			<div class="flex flex-col p-1.5 gap-0.5">
				<a
					href="/"
					class="px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee]"
				>About</a>
				<a
					href="/resume.pdf"
					target="_blank"
					rel="noopener"
					class="px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee] flex items-center gap-1.5"
				>
					Resume
					<svg class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
				<button
					type="button"
					data-theme-toggle-split
					class="px-4 py-2.5 rounded-xl text-sm font-semibold transition-colors hover:bg-black/[0.06] dark:hover:bg-white/[0.08] text-[#18181c] dark:text-[#e4e4ee] flex items-center gap-1.5 text-left w-full"
				>
					<svg class="w-4 h-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="4"></circle>
						<path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.93-7.07-1.41 1.41M6.34 17.66l-1.41 1.41"></path>
					</svg>
					<svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
					</svg>
					<span class="dark:hidden">Dark Mode</span>
					<span class="hidden dark:inline">Light Mode</span>
				</button>
			</div>
		</div>
	</div>

</header>

<script is:inline>
	/* ── Theme toggle ───────────────────────── */
	const storageKey = "theme";
	const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

	const applyTheme = (theme) => {
		document.documentElement.dataset.theme = theme;
		document.documentElement.style.colorScheme = theme;
		// Update iOS status bar color
		const tc = document.querySelector('meta[name="theme-color"]');
		if (tc) tc.setAttribute("content", theme === "dark" ? "#000000" : "#f2f2f7");
	};

	const getStoredTheme = () => localStorage.getItem(storageKey);
	applyTheme(getStoredTheme() || (mediaQuery.matches ? "dark" : "light"));

	// Both theme toggles (full nav + split menu)
	document.querySelectorAll("[data-theme-toggle], [data-theme-toggle-split]").forEach((btn) => {
		btn.addEventListener("click", () => {
			const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
			localStorage.setItem(storageKey, next);
			applyTheme(next);
		});
	});

	mediaQuery.addEventListener("change", (e) => {
		if (!getStoredTheme()) applyTheme(e.matches ? "dark" : "light");
	});

	/* ── Scroll: full pill ↔ split pills ───── */
	const navFull = document.getElementById("nav-full");
	const navSplit = document.getElementById("nav-split");
	const SCROLL_THRESHOLD = 60;
	let isScrolled = false;

	const updateNav = () => {
		const shouldCollapse = window.scrollY > SCROLL_THRESHOLD;
		if (shouldCollapse === isScrolled) return;
		isScrolled = shouldCollapse;
		if (shouldCollapse) {
			navFull.classList.add("collapsed");
			navSplit.classList.add("visible");
		} else {
			navFull.classList.remove("collapsed");
			navSplit.classList.remove("visible");
			// Also close menu dropdown when returning to top
			closeMenu();
		}
	};

	window.addEventListener("scroll", updateNav, { passive: true });
	updateNav();

	/* ── Hamburger menu dropdown ────────────── */
	const menuBtn = document.getElementById("nav-menu-btn");
	const menuDropdown = document.getElementById("nav-menu-dropdown");
	const iconOpen = document.getElementById("menu-icon-open");
	const iconClose = document.getElementById("menu-icon-close");
	let menuOpen = false;

	function closeMenu() {
		menuOpen = false;
		menuDropdown.classList.remove("open");
		iconOpen.classList.remove("hidden");
		iconClose.classList.add("hidden");
	}

	function toggleMenu() {
		menuOpen = !menuOpen;
		if (menuOpen) {
			menuDropdown.classList.add("open");
			iconOpen.classList.add("hidden");
			iconClose.classList.remove("hidden");
		} else {
			closeMenu();
		}
	}

	menuBtn.addEventListener("click", toggleMenu);

	// Close menu when clicking a link inside it
	menuDropdown.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", closeMenu);
	});
</script>
