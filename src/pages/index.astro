---
import { getImage } from "astro:assets";
import Avatar from "../images/jonathangroberg.jpeg";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/MainLayout.astro";
import { SITE_DESCRIPTION } from "../consts";

const avatarImage = await getImage({ src: Avatar, width: 128, height: 128 });

const experience = [
	{
		company: "Google YouTube",
		role: "SWE",
		location: "San Bruno, CA",
		date: "Jan 2026 – Present",
		logo: "G",
		bullet: "Implementing features for YouTube Shorts using Three.js to enhance interactive content and improve user engagement."
	},
	{
		company: "Edgedive",
		role: "Software Engineer Intern",
		location: "SF Bay Area, CA",
		date: "Oct 2025 – Dec 2025",
		logo: "E",
		bullet: "Y Combinator F24 batch company. Pushing to prod daily — fullstack."
	},
	{
		company: "Google YouTube",
		role: "Software Engineer Intern",
		location: "SF Bay Area, CA",
		date: "May 2025 – Aug 2025",
		logo: "G",
		bullet: "Deployed effects for YouTube Shorts and features for Effect Maker."
	},
	{
		company: "Fintech",
		role: "Software Engineer Intern",
		location: "Tampa, FL",
		date: "Dec 2024 – May 2025",
		logo: "F",
		bullet: "Features for Retailer Application (39% of all U.S. Alcohol Sales) and LilyPad CRM."
	},
	{
		company: "Hillsborough County Sheriff's Office",
		role: "Software Engineer Co-Op",
		location: "Tampa, FL",
		date: "Feb 2024 – Nov 2024",
		logo: "H",
		bullet: "Full-stack apps for Grants, Reports, and public-facing sites for the 5th largest Sheriff's Office in the U.S."
	},
	{
		company: "Infinite Edge Learning / CodeFu",
		role: "CS & ACT/SAT Tutor",
		location: "Tampa, FL",
		date: "Sep 2022 – Jan 2024",
		logo: "T",
		bullet: "10–15 personalized lesson plans/week in Java, Python & math — 85% of students scored AP 3+."
	},
	{
		company: "The Church Of Jesus Christ",
		role: "Data Analyst Intern",
		location: "Taichung, Taiwan",
		date: "Jul 2021 – Dec 2021",
		logo: "L",
		bullet: "Allocated $24k ad budget; built SQL + Facebook API data viz tool averaging 20% lower cost-per-click."
	}
];

const projects = [
	{
		name: "KayEcho",
		event: "Georgia Tech AI Hackathon — 1st / 150+ projects",
		tags: ["RAG", "LLM", "React", "Python", "MongoDB"],
		description: "LLM + RAG social networking tool for simulated audio and text conversations, inspired by Black Mirror's Hang the DJ."
	},
	{
		name: "Fluencia",
		event: "ShellHacks Miami — 1st in category / 400+ projects",
		tags: ["LLM", "RAG", "React"],
		description: "AI Choose Your Own Adventure story based on learned vocabulary for immersive language learning."
	},
	{
		name: "Community Link",
		event: "Morgan Stanley CodeToGive — 1st / 15 teams",
		tags: ["LLM", "React", "Python", "Vercel"],
		description: "Safe, inclusive platform for Community Restoration Project with AI flyer generation and content moderation."
	},
	{
		name: "Open Source Contributor",
		event: "",
		tags: ["Python", "C#", "Linux", "Git"],
		description: "Features for 3 Ubuntu Budgie apps, Gnome Developer Documentation contributions, GTK crypto price app."
	},
	{
		name: "Study Buddies",
		event: "OSC Hack @ UF — Finalist",
		tags: ["React", "TypeScript", "Firebase"],
		description: "Collaborative platform for UF students to discover, create, and join study groups with messaging and scheduling."
	},
	{
		name: "Bookface",
		event: "",
		tags: ["React", "REST-API", "AWS"],
		description: "Social media platform for developers to connect and share code snippets and project updates."
	}
];

const education = [
	{
		name: "University of Florida",
		location: "Gainesville, FL",
		degree: "B.S. Computer Science · Minor Business Administration",
		date: "May 2024",
		gpa: "3.95",
		highlights: [
			"3× Hackathon Winner · Grow with Google Scholar · Georgia Tech Startup Exchange Fellow · Eagle Scout",
			"Open Source Club · ColorStack · Society of Professional Hispanic Engineers"
		]
	},
	{
		name: "Hillsborough Community College",
		location: "Tampa, FL",
		degree: "A.A. Engineering",
		date: "Aug 2023",
		gpa: "3.6",
		highlights: ["Dean's List (all 3 semesters)"]
	}
];

const logoColors: Record<string, string> = {
	G: "bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-300",
	E: "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-300",
	F: "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300",
	H: "bg-teal-100 text-teal-700 dark:bg-teal-900/50 dark:text-teal-300",
	T: "bg-purple-100 text-purple-700 dark:bg-purple-900/50 dark:text-purple-300",
	L: "bg-pink-100 text-pink-700 dark:bg-pink-900/50 dark:text-pink-300",
	U: "bg-orange-100 text-orange-700 dark:bg-orange-900/50 dark:text-orange-300"
};
---

<Layout title="Home" description={SITE_DESCRIPTION}>
	<Header />
	<main>

		<!-- ── Profile card ───────────────────────────────── -->
		<div class="glass p-6 mb-3 text-center">
			<img
				src={avatarImage.src}
				alt="Jonathan Groberg"
				loading="eager"
				class="w-20 h-20 rounded-full mx-auto mb-3 object-cover border-2 border-white/60 shadow-md"
			/>
			<h1 class="text-xl font-bold mb-0.5 text-[#18181c] dark:text-[#e4e4ee]">Jonathan Groberg</h1>
			<p class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 mb-1">SWE @ YouTube</p>
			<p class="text-xs text-black/40 dark:text-white/40">
				CS Graduate · University of Florida 🐊 · SF Bay 📍
			</p>
		</div>

		<!-- ── Link buttons (Linktree style) ─────────────── -->
		<div class="grid grid-cols-2 gap-2 mb-2">
			<a
				href="https://github.com/joncgroberg"
				target="_blank"
				rel="noopener"
				class="glass-btn"
			>
				<svg viewBox="0 0 16 16" class="w-4 h-4 flex-shrink-0" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
				</svg>
				GitHub
			</a>
			<a
				href="https://www.linkedin.com/in/jonathan-groberg/"
				target="_blank"
				rel="noopener"
				class="glass-btn"
			>
				<svg viewBox="0 0 24 24" class="w-4 h-4 flex-shrink-0 text-blue-600 dark:text-sky-400" fill="currentColor" aria-hidden="true">
					<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
				</svg>
				LinkedIn
			</a>
		</div>
		<div class="flex flex-col gap-2 mb-3">
			<a href="/blog" class="glass-btn">
				<svg viewBox="0 0 24 24" class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 20h9"></path>
					<path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
				</svg>
				Blog
			</a>
			<a href="/resume.pdf" target="_blank" rel="noopener" class="glass-btn">
				<svg viewBox="0 0 24 24" class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
					<polyline points="14 2 14 8 20 8"></polyline>
					<line x1="16" y1="13" x2="8" y2="13"></line>
					<line x1="16" y1="17" x2="8" y2="17"></line>
					<polyline points="10 9 9 9 8 9"></polyline>
				</svg>
				Resume / CV
			</a>
		</div>

		<!-- ── Experience / Projects / Education ─────────── -->
		<div class="glass overflow-hidden">

			<!-- Segmented control -->
			<div class="p-2">
				<div class="flex rounded-xl bg-black/[0.05] dark:bg-white/[0.05] p-0.5">
					<button class="seg-tab active" data-tab="experience">Experience</button>
					<button class="seg-tab" data-tab="projects">Projects</button>
					<button class="seg-tab" data-tab="education">Education</button>
				</div>
			</div>

			<!-- Scrollable content -->
			<div class="overflow-y-auto scrollbar-hide px-4 pb-4" style="max-height: 65vh;">

				<!-- Experience -->
				<div id="tab-experience" class="tab-content divide-y divide-black/[0.06] dark:divide-white/[0.06]">
					{experience.map((exp) => (
						<div class="flex gap-3 py-3.5">
							<div class={`flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold ${logoColors[exp.logo] ?? "bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300"}`}>
								{exp.logo}
							</div>
							<div class="flex-1 min-w-0">
								<p class="text-sm font-bold text-[#18181c] dark:text-[#e4e4ee] mb-0">
									{exp.role}
									<span class="font-normal text-black/50 dark:text-white/50"> @ {exp.company}</span>
								</p>
								<p class="text-xs text-black/40 dark:text-white/40 mb-1">{exp.date} · {exp.location}</p>
								<p class="text-sm text-black/65 dark:text-white/65">{exp.bullet}</p>
							</div>
						</div>
					))}
				</div>

				<!-- Projects -->
				<div id="tab-projects" class="tab-content hidden divide-y divide-black/[0.06] dark:divide-white/[0.06]">
					{projects.map((proj) => (
						<div class="py-3.5">
							<p class="text-sm font-bold text-[#18181c] dark:text-[#e4e4ee] mb-0">{proj.name}</p>
							{proj.event && (
								<p class="text-xs text-black/40 dark:text-white/40 mb-1.5">{proj.event}</p>
							)}
							<div class="flex flex-wrap gap-1 mb-1.5">
								{proj.tags.map((tag) => (
									<span class="text-[10px] px-2 py-0.5 rounded-full font-mono bg-indigo-100/70 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
										{tag}
									</span>
								))}
							</div>
							<p class="text-sm text-black/65 dark:text-white/65">{proj.description}</p>
						</div>
					))}
				</div>

				<!-- Education -->
				<div id="tab-education" class="tab-content hidden divide-y divide-black/[0.06] dark:divide-white/[0.06]">
					{education.map((edu) => (
						<div class="py-3.5">
							<p class="text-sm font-bold text-[#18181c] dark:text-[#e4e4ee] mb-0">{edu.degree}</p>
							<p class="text-sm text-black/60 dark:text-white/60">{edu.name} · {edu.location}</p>
							<p class="text-xs text-black/40 dark:text-white/40 mb-1.5">{edu.date} · GPA {edu.gpa}</p>
							<ul class="text-sm text-black/65 dark:text-white/65 space-y-0.5 list-disc ml-4">
								{edu.highlights.map((h) => <li>{h}</li>)}
							</ul>
						</div>
					))}
				</div>

			</div>
		</div>

	</main>
	<Footer />
</Layout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const buttons = document.querySelectorAll<HTMLElement>(".seg-tab");
		const contents = document.querySelectorAll(".tab-content");

		buttons.forEach((btn) => {
			btn.addEventListener("click", () => {
				const tab = btn.dataset.tab;

				buttons.forEach((b) => b.classList.remove("active"));
				contents.forEach((c) => c.classList.add("hidden"));

				btn.classList.add("active");
				document.getElementById(`tab-${tab}`)?.classList.remove("hidden");
			});
		});
	});
</script>
